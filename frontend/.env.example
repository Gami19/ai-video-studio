# Backend API のベース URL
# ローカル開発: wrangler dev で起動した Workers の URL（デフォルト http://localhost:8787）
# 本番: Cloudflare Pages の Environment variables に Workers URL を設定
# 例（計画書の Worker ホスト）: https://ai-video-studio-backend.k-ikegami-15.workers.dev
# ※ Worker の ALLOWED_ORIGINS に Pages のオリジン（例: https://ai-video-studio-frontend.pages.dev）を含めること
VITE_API_URL=http://localhost:8787

# 本番ビルドでもコンソールに [ai-video-studio] デバッグログを出す（任意）
# VITE_DEBUG=true
