# Backend API のベース URL
#
# 本番（Pages BFF・同一オリジン）: 未設定または空のままにする。
#   ビルド後のフロントは `/api/...` を叩き、Pages Functions が Worker にプロキシする。
#   Worker の URL は Cloudflare Pages の Environment variables に
#   BACKEND_API_ORIGIN（VITE_ なし）で設定する。
#
# ローカルで Worker に直接接続: wrangler dev の URL（例: http://localhost:8787）
# ※ Worker の ALLOWED_ORIGINS にフロントのオリジンを含めること
VITE_API_URL=http://localhost:8787

# 本番ビルドでもコンソールに [ai-video-studio] デバッグログを出す（任意）
# VITE_DEBUG=true

# API レスポンスの分析文プレビューをログに含める（本番では未設定推奨）
# VITE_LOG_API_BODY_PREVIEW=true
